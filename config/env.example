# API keys for openmud chat (used by /api/chat serverless function)
#
# Add these to your openmud Vercel project:
# Project → Settings → Environment Variables
#
# Never commit real keys. Never paste keys in chat.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...    # From Stripe CLI or Dashboard webhook

# Stripe price IDs (one per tier)
STRIPE_PRICE_PERSONAL=price_...    # openmud Personal
STRIPE_PRICE_PRO=price_...         # openmud Pro (or use STRIPE_PRICE_ID for backward compat)
STRIPE_PRICE_EXECUTIVE=price_...   # openmud Executive

# Supabase (auth + user database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...   # Publishable key (client-safe)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_... # Secret key (server-only)
